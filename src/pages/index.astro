    <!-- ===================================================================== -->
    <!-- LÓGICA DE TABS (JavaScript Vanilla)                                     -->
    <!-- ===================================================================== -->
    <script>
      // ====================================================================
      //  NAVEGACIÓN POR TABS
      // ====================================================================
      const buttons = document.querySelectorAll("[data-tab]");
      const panels = document.querySelectorAll("[data-panel]");
      const scroller = document.getElementById("content-scroll");

      // Tabs que muestran el fondo de nodos animados (inicio y cierre).
      const NODE_TABS = new Set(["diagnostico", "inversion"]);

      function activate(id) {
        // Muestra/oculta paneles
        panels.forEach((panel) => {
          panel.classList.toggle("hidden", panel.dataset.panel !== id);
        });
        // Marca el botón activo en todos los navegadores (sidebar + móvil)
        buttons.forEach((btn) => {
          const isActive = btn.dataset.tab === id;
          btn.classList.toggle("tab-active", isActive);
          if (isActive) btn.setAttribute("aria-current", "page");
          else btn.removeAttribute("aria-current");
        });
        // Activa/desactiva el fondo de nodos según la pestaña
        nodes.setActive(NODE_TABS.has(id));
        // Cierra el menú móvil al navegar
        setMenu(false);
        // Vuelve arriba al cambiar de sección
        scroller?.scrollTo({ top: 0, behavior: "smooth" });
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => activate(btn.dataset.tab));
      });

      // ====================================================================
      //  MENÚ SÁNDWICH (móvil)
      // ====================================================================
      const mobileMenu = document.getElementById("mobile-menu");
      const menuToggle = document.getElementById("menu-toggle");
      const iconOpen = document.getElementById("menu-icon-open");
      const iconClose = document.getElementById("menu-icon-close");
      function setMenu(open) {
        if (!mobileMenu) return;
        mobileMenu.classList.toggle("hidden", !open);
        iconOpen?.classList.toggle("hidden", open);
        iconClose?.classList.toggle("hidden", !open);
      }
      menuToggle?.addEventListener("click", () => {
        setMenu(mobileMenu.classList.contains("hidden"));
      });

      // ====================================================================
      //  FONDO DE NODOS ANIMADOS E INTERACTIVOS (canvas vanilla)
      // ====================================================================
      const nodes = (() => {
        const canvas = document.getElementById("bg-nodes");
        const ctx = canvas.getContext("2d");
        const prefersReduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;

        let dpr = 1;
        let w = 0;
        let h = 0;
        let offsetLeft = 0;
        let particles = [];
        let raf = null;
        let active = false;
        let count = 46;
        const mouse = { x: null, y: null };

        // Parámetros idénticos a matiaslaporta.com (#network-canvas)
        const SIDEBAR_W = 288; // w-72 = 18rem = 288px
        const COUNT_DESKTOP = 46; // nodos en desktop (−35% respecto a los 70 originales)
        const COUNT_MOBILE = 20; // nodos en móvil
        const LINK_DIST = 120; // distancia para unir nodos entre sí
        const MOUSE_DIST = 180; // radio de interacción con el cursor
        const COLOR = "0, 229, 255"; // #00E5FF

        function resize() {
          // El <canvas> es un elemento reemplazado: NO se estira con inset CSS.
          // Lo dimensionamos explícitamente para cubrir el área de contenido.
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          const isLg = window.matchMedia("(min-width: 1024px)").matches;
          offsetLeft = isLg ? SIDEBAR_W : 0;
          count = isLg ? COUNT_DESKTOP : COUNT_MOBILE;
          w = window.innerWidth - offsetLeft;
          h = window.innerHeight;
          canvas.style.left = offsetLeft + "px";
          canvas.style.width = w + "px";
          canvas.style.height = h + "px";
          canvas.width = Math.round(w * dpr);
          canvas.height = Math.round(h * dpr);
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          seed();
        }

        function seed() {
          // Cantidad de nodos según el dispositivo (móvil vs desktop)
          particles = Array.from({ length: count }, () => ({
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * 1.5,
            vy: (Math.random() - 0.5) * 1.5,
            radius: Math.random() * 2 + 1,
          }));
        }

        function step() {
          ctx.clearRect(0, 0, w, h);

          // 1) Mover y dibujar cada nodo
          particles.forEach((p) => {
            p.x += p.vx;
            p.y += p.vy;
            if (p.x < 0 || p.x > w) p.vx *= -1;
            if (p.y < 0 || p.y > h) p.vy *= -1;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
            ctx.fillStyle = "#00E5FF";
            ctx.fill();
          });

          // 2) Líneas hacia el cursor + entre nodos
          for (let i = 0; i < particles.length; i++) {
            // Línea hacia el cursor (sin atracción, solo conexión visual)
            if (mouse.x != null) {
              const sx = particles[i].x - mouse.x;
              const sy = particles[i].y - mouse.y;
              const l = Math.sqrt(sx * sx + sy * sy);
              if (l < MOUSE_DIST) {
                ctx.beginPath();
                ctx.strokeStyle = `rgba(${COLOR}, ${0.5 * (1 - l / MOUSE_DIST)})`;
                ctx.lineWidth = 1.5;
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(mouse.x, mouse.y);
                ctx.stroke();
              }
            }
            // Líneas entre nodos cercanos
            for (let j = i; j < particles.length; j++) {
              const dx = particles[i].x - particles[j].x;
              const dy = particles[i].y - particles[j].y;
              const d = Math.sqrt(dx * dx + dy * dy);
              if (d < LINK_DIST) {
                ctx.beginPath();
                ctx.strokeStyle = `rgba(${COLOR}, ${0.2 * (1 - d / LINK_DIST)})`;
                ctx.lineWidth = 1;
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.stroke();
              }
            }
          }

          raf = requestAnimationFrame(step);
        }

        function start() {
          if (raf || prefersReduced) return;
          raf = requestAnimationFrame(step);
        }

        function stop() {
          if (raf) cancelAnimationFrame(raf);
          raf = null;
        }

        function setActive(on) {
          active = on;
          canvas.classList.toggle("hidden", !on);
          if (on) {
            resize();
            if (prefersReduced) {
              // Render estático único si el usuario reduce movimiento
              step();
              stop();
            } else {
              start();
            }
          } else {
            stop();
            ctx.clearRect(0, 0, w, h);
          }
        }

        // Eventos
        window.addEventListener("resize", () => {
          if (active) resize();
        });
        function onMove(clientX, clientY) {
          mouse.x = clientX - offsetLeft;
          mouse.y = clientY;
        }
        window.addEventListener("pointermove", (e) => onMove(e.clientX, e.clientY));
        window.addEventListener("pointerleave", () => {
          mouse.x = null;
          mouse.y = null;
        });

        return { setActive };
      })();

      // Tab 1 visible por defecto + estilo activo + nodos encendidos
      activate("diagnostico");
    </script>
