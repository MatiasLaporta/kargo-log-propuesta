---
// =============================================================================
//  PROPUESTA COMERCIAL CONFIDENCIAL — Kargo-Log (Sergio Cachay)
//  Layout "Presentación Ejecutiva": sidebar fijo + tabs (JS vanilla).
//  Mobile First · Astro + Tailwind CSS. SEO omitido a propósito.
// =============================================================================
import "../styles/global.css";

// --- Índice de navegación (sidebar + barra móvil) ---------------------------
const tabs = [
  { id: "diagnostico", n: "01", label: "Diagnóstico y Contexto" },
  { id: "soluciones",  n: "02", label: "El Sistema (Soluciones)" },
  { id: "showcase",    n: "03", label: "Showcase Kargo-Log" },
  { id: "inversion",   n: "04", label: "Inversión y Cronograma" },
];

// --- Datos del embudo (centralizados para edición rápida) -------------------
const modulos = [
  {
    n: "01",
    titulo: "Optimización de LinkedIn",
    desc: "Perfil de empresa optimizado (titular, acerca de, servicios, destacado), optimización técnica del algoritmo y auditoría SSI de los 4 pilares.",
    bonus: "Perfil de LinkedIn Personal optimizado.",
  },
  {
    n: "02",
    titulo: 'Prospección Orgánica "Straight Line"',
    desc: "Script de conexión, entrega de valor y CTA. Lead Magnet, embudo de conversión por autoridad y calendario de cadencia diaria.",
    bonus: "Cadencia de referidos (pedido, contacto y seguimiento).",
  },
  {
    n: "03",
    titulo: "Cierre de Ventas",
    desc: "Guion técnico de llamada de descubrimiento para Google Meet, matriz de manejo de objeciones y deck de propuesta (5–7 slides).",
    bonus: "Pipeline de seguimiento (CRM simple).",
  },
  {
    n: "04",
    titulo: "Estrategia e IA Comercial",
    desc: "Oferta express con CTA claro y agentes de IA para grilla de contenidos, redacción de entregables y pricing nacional.",
    bonus: "Agente de IA para estructurar honorarios internacionales.",
  },
  {
    n: "05",
    titulo: "Activos Digitales (Landing Pages)",
    desc: "Landing que funciona como embudo de ventas, con CTA claro y optimización SEO, AEO y GEO.",
    bonus: "Landing estilo tarjeta digital.",
  },
];

const descartadas = [
  {
    titulo: "Agencias (CM)",
    desc: "No necesitas publicaciones diarias de \"feliz viernes\" ni diseños corporativos vacíos. Tu cliente ideal, un dueño de PYME saturado de problemas, valora el contenido técnico, la profundidad de análisis y los mensajes directos a su dolor, no la estética superficial.",
  },
  {
    titulo: "Google Ads",
    desc: "Atrae tráfico masivo de baja calidad (personas buscando fletes pequeños o mudanzas B2C). La probabilidad que un gerente de operaciones de una planta industrial busque un consultor de logística haciendo clic en un anuncio genérico de Google es bajísima.",
  },
  {
    titulo: "LinkedIn Ads",
    desc: "El costo por clic es prohibitivo en tu nicho. Pagar por publicidad cuando tu perfil personal y el de la empresa no están optimizados para retener esa visita es quemar presupuesto que rebotará de inmediato.",
  },
];

const precios = [
  { item: "Optimización de LinkedIn", usd: 300, pen: "1.125" },
  { item: "Prospección Orgánica", usd: 250, pen: "937,50" },
  { item: "Cierre de Ventas", usd: 350, pen: "1.312,50" },
  { item: "Estrategia e IA Comercial", usd: 200, pen: "750" },
  { item: "Activos Digitales (Landing)", usd: 200, pen: "750" },
];

const cronograma = [
  { semana: "Semana 1", hito: "Firma del contrato, pago de honorarios y análisis e investigación del caso." },
  { semana: "Semana 2", hito: "Entrega de la planificación de los servicios contratados." },
  { semana: "Semana 3", hito: "Ajustes según feedback del cliente." },
  { semana: "Semanas 4–8", hito: "Implementación y acompañamiento." },
];
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Propuesta Kargo-Log 2026 | Matías Laporta</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root { font-family: "Inter", ui-sans-serif, system-ui, sans-serif; }
      body { font-family: "Inter", ui-sans-serif, system-ui, sans-serif; }

      /* Estado activo del navegador de tabs (sidebar vs barra móvil) */
      .nav-side.tab-active {
        background: rgba(34, 211, 238, 0.1);
        color: #fff;
        box-shadow: inset 2px 0 0 #22d3ee;
      }
      .nav-side.tab-active .nav-num { color: #22d3ee; }
      .nav-top.tab-active {
        background: #06b6d4;
        color: #0f172a;
        border-color: #06b6d4;
      }
    </style>
  </head>

  <body class="min-h-screen bg-[#0f172a] text-slate-300 antialiased">
    <!-- ===================================================================== -->
    <!-- SIDEBAR (FIJO en lg+)                                                   -->
    <!-- ===================================================================== -->
    <aside
      class="hidden lg:flex lg:fixed lg:inset-y-0 lg:left-0 lg:w-72 lg:flex-col z-30 border-r border-slate-800/80 bg-[#0b0f19]"
    >
      <!-- Encabezado de la propuesta -->
      <div class="border-b border-slate-800/80 px-6 py-7">
        <div class="flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-yellow-400"></span>
          <span class="text-[11px] font-semibold tracking-widest text-slate-500 uppercase">
            Propuesta confidencial
          </span>
        </div>
        <h2 class="mt-3 text-lg font-bold leading-tight text-white">
          Propuesta <span class="text-yellow-400">Kargo-Log</span> 2026
        </h2>
      </div>

      <!-- Navegación -->
      <nav class="flex-1 overflow-y-auto px-3 py-5">
        <ul class="space-y-1">
          {
            tabs.map((t) => (
              <li>
                <button
                  type="button"
                  data-tab={t.id}
                  class="nav-side group flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-left text-sm font-medium text-slate-400 transition hover:bg-slate-800/50 hover:text-white"
                >
                  <span class="nav-num font-mono text-xs text-slate-600 tabular-nums transition">
                    {t.n}
                  </span>
                  <span>{t.label}</span>
                </button>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Footer del sidebar -->
      <div class="border-t border-slate-800/80 px-6 py-5">
        <a
          href="https://calendar.app.google/mTu5R8CYQ7A2BKYZ7"
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full rounded-lg bg-yellow-400 px-4 py-3 text-center text-sm font-semibold text-slate-900 transition hover:bg-yellow-300"
        >
          Agendar Kick-off
        </a>
      </div>
    </aside>

    <!-- ===================================================================== -->
    <!-- BARRA SUPERIOR MÓVIL (lg:hidden)                                        -->
    <!-- ===================================================================== -->
    <header class="lg:hidden sticky top-0 z-20 border-b border-slate-800/80 bg-[#0b0f19]/95 backdrop-blur">
      <div class="flex items-center justify-between px-4 py-4">
        <h2 class="text-base font-bold text-white">
          Propuesta <span class="text-yellow-400">Kargo-Log</span> 2026
        </h2>
      </div>
      <nav class="flex gap-2 overflow-x-auto px-4 pb-3">
        {
          tabs.map((t) => (
            <button
              type="button"
              data-tab={t.id}
              class="nav-top shrink-0 rounded-full border border-slate-700 px-4 py-1.5 text-xs font-medium whitespace-nowrap text-slate-300 transition"
            >
              {t.label}
            </button>
          ))
        }
      </nav>
    </header>

    <!-- ===================================================================== -->
    <!-- ÁREA DE CONTENIDO (scrolleable)                                         -->
    <!-- ===================================================================== -->
    <!-- Fondo de nodos animados (solo visible en tabs Resumen e Inversión) -->
    <canvas
      id="bg-nodes"
      class="pointer-events-none fixed top-0 left-0 z-0 hidden"
      aria-hidden="true"
    ></canvas>

    <main id="content-scroll" class="relative z-10 lg:ml-72 lg:h-screen lg:overflow-y-auto">
      <div class="mx-auto flex min-h-screen max-w-6xl flex-col justify-center px-6 py-14 sm:px-10 sm:py-16 lg:px-16 lg:py-24">

        <!-- ============================ TAB 01 ============================ -->
        <!-- DIAGNÓSTICO Y CONTEXTO (Hero + PAS + Autoridad + Comparativa)      -->
        <section data-panel="diagnostico">

          <!-- ----- Bloque A: El Gancho (Hero) ----- -->
          <div>
            <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
              Propuesta de estrategia comercial B2B exclusiva para Sergio Cachay / Kargo-Log
            </p>
            <h1 class="mt-6 text-balance text-4xl font-bold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl">
              25 años de excelencia operativa en empresas como
              <span class="text-white">P&amp;G</span> y <span class="text-white">Derco</span>
              no sirven de nada si los dueños de PYMES
              <span class="text-yellow-400">no saben que existes.</span>
            </h1>
            <p class="mt-8 max-w-3xl text-lg leading-relaxed text-slate-400 lg:text-xl">
              Pasar de esperar referidos a
              <span class="font-medium text-slate-200">prospectar clientes high-ticket</span>
              requiere un sistema. Construyamos tu maquinaria de adquisición en LinkedIn.
            </p>
            <div class="mt-10 flex flex-col gap-4 sm:flex-row">
              <button
                type="button"
                data-tab="soluciones"
                class="inline-flex items-center justify-center rounded-lg bg-cyan-500 px-7 py-3.5 text-sm font-semibold text-slate-900 transition hover:bg-cyan-400"
              >
                Ver el sistema
              </button>
              <button
                type="button"
                data-tab="inversion"
                class="inline-flex items-center justify-center rounded-lg border border-slate-700 px-7 py-3.5 text-sm font-semibold text-slate-200 transition hover:border-slate-500 hover:bg-slate-800/50"
              >
                Inversión y cronograma
              </button>
            </div>
          </div>

          <!-- ----- Bloque B: Agitación cruda del dolor (PAS) ----- -->
          <div class="mt-16 border-t border-slate-800/60 py-16">
            <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
              El Diagnóstico
            </p>
            <h2 class="mt-5 max-w-3xl text-3xl font-bold leading-snug tracking-tight text-white sm:text-4xl lg:text-5xl">
              Por qué tu trayectoria
              <span class="text-yellow-400">no se está traduciendo en contratos.</span>
            </h2>

            <div class="mt-10 space-y-10">
              <!-- Sub-bloque 1 -->
              <div class="border-l-2 border-cyan-500/40 pl-5 sm:pl-6">
                <h3 class="text-lg font-semibold text-white lg:text-xl">
                  El Síndrome del Currículum de Oro.
                </h3>
                <p class="mt-3 max-w-3xl text-base leading-relaxed text-slate-400 lg:text-lg">
                  Tienes un trasfondo corporativo impecable, un MBA y soluciones reales para optimizar
                  almacenes e inventarios. El problema es que los dueños de empresas familiares y PYMES
                  de 50 a 200 colaboradores no compran "teoría corporativa". Ellos viven en el caos
                  operativo diario. Si te comunicas como un ejecutivo de multinacional en lugar de
                  alguien que resuelva "incendios" de forma práctica, te verán como un
                  <span class="text-slate-200">gasto inalcanzable</span> y no como una solución directa.
                </p>
              </div>

              <!-- Sub-bloque 2 -->
              <div class="border-l-2 border-cyan-500/40 pl-5 sm:pl-6">
                <h3 class="text-lg font-semibold text-white lg:text-xl">
                  La Muerte del Brochure Pasivo.
                </h3>
                <p class="mt-3 max-w-3xl text-base leading-relaxed text-slate-400 lg:text-lg">
                  Enviar brochures informativos y materiales promocionales a tus contactos conocidos o
                  grupos de WhatsApp tiene un techo muy bajo. Los resultados han sido limitados porque
                  el brochure es un elemento pasivo: espera que el cliente tenga el tiempo de leerlo,
                  entenderlo y llamarte. En B2B, el cliente no busca,
                  <span class="text-slate-200">al cliente se le prospecta con un ángulo de valor
                  quirúrgico.</span>
                </p>
              </div>

              <!-- Sub-bloque 3 -->
              <div class="border-l-2 border-yellow-400/50 pl-5 sm:pl-6">
                <h3 class="text-lg font-semibold text-white lg:text-xl">
                  El Elefante en la Habitación (La Identidad Dual).
                </h3>
                <p class="mt-3 max-w-3xl text-base leading-relaxed text-slate-400 lg:text-lg">
                  Detengamos el debate de si debes posicionar tu nombre o la marca Kargo-Log. En la
                  consultoría de alto valor para PYMES,
                  <strong class="font-semibold text-yellow-400">los directores le compran a personas,
                  no a logotipos corporativos sin rostro.</strong> Kargo-Log es la marca que te da el
                  respaldo operativo y comercial, pero
                  <strong class="font-semibold text-white">Sergio Cachay es la autoridad de
                  confianza</strong> que cierra el trato. No vamos a elegir una: vamos a fusionar ambas
                  en un solo ecosistema de atracción donde tu nombre abre la puerta y tu marca respalda
                  la operación.
                </p>
              </div>
            </div>
          </div>

          <!-- ----- Bloque C: Autoridad (Tu Rol) ----- -->
          <div class="border-t border-slate-800/60 py-16">
            <div class="grid gap-8 lg:grid-cols-2 lg:gap-14">
              <div>
                <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
                  Mi Rol
                </p>
                <h2 class="mt-5 text-3xl font-bold leading-snug tracking-tight text-white sm:text-4xl lg:text-5xl">
                  Consultoría B2B con foco en
                  <span class="text-yellow-400">LinkedIn</span>.
                </h2>
              </div>
              <div class="text-lg leading-relaxed text-slate-400 lg:pt-2 lg:text-xl">
                <p>
                  Diseño y operación de
                  <span class="text-slate-200">embudos de conversión orgánicos</span> en LinkedIn para
                  consultores y empresas. No vendemos humo ni alcance vacío: construimos autoridad
                  digital que se convierte en
                  <span class="text-slate-200">reuniones calificadas.</span>
                </p>
              </div>
            </div>
          </div>

          <!-- ----- Bloque D: Estrategias descartadas (Comparativa) ----- -->
          <div class="border-t border-slate-800/60 py-16">
            <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
              Estrategias descartadas
            </p>
            <h2 class="mt-5 text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
              <span class="lg:whitespace-nowrap">Por qué el marketing tradicional</span><br />
              <span class="text-yellow-400">fracasa en tu industria.</span>
            </h2>
            <div class="mt-12 grid gap-6 md:grid-cols-3">
              {
                descartadas.map((c) => (
                  <div class="rounded-xl border border-slate-800 bg-[#0b0f19]/60 p-6 transition hover:border-slate-700">
                    <div class="flex items-center gap-3">
                      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-red-500/30 bg-red-500/10 text-red-400">
                        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M5 5l10 10M15 5L5 15" stroke-linecap="round" />
                        </svg>
                      </div>
                      <h3 class="text-lg font-semibold text-white lg:text-xl">{c.titulo}</h3>
                    </div>
                    <p class="mt-4 text-sm leading-relaxed text-slate-400 lg:text-base">{c.desc}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </section>

        <!-- ============================ TAB 02 ============================ -->
        <section data-panel="soluciones" class="hidden">
          <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
            El Sistema
          </p>
          <h2 class="mt-5 max-w-2xl text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
            5 pilares para un embudo <span class="text-yellow-400">predecible</span>.
          </h2>
          <div class="mt-12 space-y-4">
            {
              modulos.map((m) => (
                <div class="grid gap-4 rounded-xl border border-slate-800 bg-[#0b0f19]/60 p-6 transition hover:border-cyan-500/40 sm:grid-cols-[auto_1fr] sm:gap-6">
                  <span class="font-mono text-2xl font-bold text-cyan-400/80 tabular-nums">
                    {m.n}
                  </span>
                  <div>
                    <h3 class="text-lg font-semibold text-white lg:text-xl">{m.titulo}</h3>
                    <p class="mt-2 text-sm leading-relaxed text-slate-400 lg:text-base">{m.desc}</p>
                    <p class="mt-4 inline-flex flex-wrap items-center gap-2 rounded-lg border border-yellow-400/20 bg-yellow-400/5 px-3 py-1.5 text-sm">
                      <span class="text-xs font-bold tracking-wide text-yellow-400 uppercase">Bonus</span>
                      <span class="text-slate-300">{m.bonus}</span>
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        <!-- ============================ TAB 03 ============================ -->
        <!-- SHOWCASE (lienzo claro que rompe el patrón oscuro)                 -->
        <section data-panel="showcase" class="hidden">
          <div class="overflow-hidden rounded-3xl bg-gray-100 text-gray-900 shadow-2xl shadow-black/40">
            <div class="p-8 sm:p-12 lg:p-16">
              <p class="text-xs font-semibold tracking-widest text-orange-600 uppercase">
                Showcase · Previsualización Alpha
              </p>
              <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                Tu nueva identidad digital:
                <span class="text-[#1e3a8a]">Kargo</span><span class="text-orange-600">-Log</span>
              </h2>

              <!-- Logotipo horizontal (Propuesta 1) -->
              <div class="mt-10 flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-6 py-16 shadow-sm">
                <span class="text-5xl font-extrabold tracking-tight sm:text-6xl lg:text-7xl">
                  <span class="text-[#1e3a8a]">KARGO</span><span class="text-orange-600">-LOG</span>
                  <span class="ml-1 inline-block text-orange-600" aria-hidden="true">&rarr;</span>
                </span>
              </div>

              <!-- Justificación de diseño (análisis de color) -->
              <div class="mt-8 grid gap-5 sm:grid-cols-2">
                <div class="rounded-xl border border-gray-200 bg-white p-6">
                  <div class="flex items-center gap-3">
                    <span class="h-8 w-8 rounded-md border border-black/10 bg-[#1e3a8a]"></span>
                    <div>
                      <p class="text-sm font-semibold text-gray-900">KARGO · Azul Marino</p>
                      <p class="font-mono text-xs text-gray-500">#1E3A8A</p>
                    </div>
                  </div>
                  <p class="mt-4 text-sm leading-relaxed text-gray-600">
                    Denota la <span class="font-semibold text-gray-900">solidez del respaldo
                    corporativo</span>: 25 años de trayectoria operativa que dan confianza al decisor.
                  </p>
                </div>
                <div class="rounded-xl border border-gray-200 bg-white p-6">
                  <div class="flex items-center gap-3">
                    <span class="h-8 w-8 rounded-md border border-black/10 bg-orange-600"></span>
                    <div>
                      <p class="text-sm font-semibold text-gray-900">LOG · Naranja Industrial</p>
                      <p class="font-mono text-xs text-gray-500">#EA580C</p>
                    </div>
                  </div>
                  <p class="mt-4 text-sm leading-relaxed text-gray-600">
                    La flecha integrada transmite
                    <span class="font-semibold text-gray-900">tracción logística</span> y la
                    eliminación de cuellos de botella en la cadena.
                  </p>
                </div>
              </div>

              <!-- Placeholder para los activos alfa -->
              <div class="mt-8 flex aspect-[16/9] items-center justify-center rounded-2xl border-2 border-dashed border-gray-300 bg-gray-50 px-6 text-center">
                <span class="max-w-md text-sm font-medium text-gray-400">
                  [Previsualización Alfa: Landing Page Principal y Tarjeta de Presentación
                  Digital — Digital-Card]
                </span>
              </div>
            </div>
          </div>
        </section>

        <!-- ============================ TAB 04 ============================ -->
        <section data-panel="inversion" class="hidden">
          <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
            Inversión
          </p>
          <h2 class="mt-5 text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
            Inversión y <span class="text-yellow-400">cronograma</span>.
          </h2>

          <!-- Desglose + ofertas -->
          <div class="mt-10 grid gap-6 lg:grid-cols-[3fr_2fr]">
            <!-- Módulos individuales -->
            <div class="rounded-xl border border-slate-800 bg-[#0b0f19]/60 p-6 sm:p-7">
              <h3 class="text-xs font-semibold tracking-widest text-slate-400 uppercase">
                Módulos individuales
              </h3>
              <ul class="mt-5 divide-y divide-slate-800">
                {
                  precios.map((p) => (
                    <li class="flex items-baseline justify-between gap-4 py-3">
                      <span class="text-sm text-slate-300">{p.item}</span>
                      <span class="text-right whitespace-nowrap">
                        <span class="font-semibold text-white tabular-nums">${p.usd}</span>
                        <span class="ml-2 font-mono text-xs text-slate-500">S/ {p.pen}</span>
                      </span>
                    </li>
                  ))
                }
              </ul>
              <div class="mt-4 flex items-baseline justify-between border-t border-slate-700 pt-4">
                <span class="text-sm font-semibold tracking-wide text-slate-200 uppercase">Total</span>
                <span class="text-right">
                  <span class="text-xl font-bold text-white tabular-nums">$1,300 USD</span>
                  <span class="ml-2 font-mono text-xs text-slate-500">S/ 4.875</span>
                </span>
              </div>
            </div>

            <!-- Ofertas -->
            <div class="space-y-5">
              <div class="rounded-xl border border-slate-800 bg-[#0b0f19]/60 p-6">
                <div class="flex items-center justify-between">
                  <h3 class="text-base font-semibold text-white">Paquete 3 Módulos</h3>
                  <span class="rounded-full bg-slate-800 px-3 py-1 text-xs font-bold text-slate-300">
                    15% OFF
                  </span>
                </div>
                <p class="mt-3 text-sm text-slate-400">
                  Elige tres pilares del sistema y aplica un 15% de descuento sobre el total
                  combinado.
                </p>
              </div>

              <!-- Full Stack (destacada) -->
              <div class="relative overflow-hidden rounded-xl border border-cyan-500/50 bg-gradient-to-b from-cyan-500/10 to-[#0b0f19]/60 p-6">
                <span class="absolute right-4 top-4 rounded-full bg-cyan-500 px-3 py-1 text-xs font-bold text-slate-900">
                  30% OFF
                </span>
