---
// =============================================================================
//  PROPUESTA COMERCIAL CONFIDENCIAL — Kargo-Log (Sergio Cachay)
//  Maquetación de embudo B2B. Mobile First · Tailwind CSS.
//  SEO omitido a propósito (foco en el funnel y la maquetación).
// =============================================================================

import "../styles/global.css";

// --- Datos del embudo (centralizados para edición rápida) -------------------
const modulos = [
  {
    n: "01",
    titulo: "Setting y Optimización de LinkedIn",
    desc: "Perfil de empresa optimizado (titular, acerca de, servicios, destacado), optimización técnica del algoritmo y auditoría SSI de los 4 pilares.",
    bonus: "Perfil de LinkedIn Personal optimizado.",
  },
  {
    n: "02",
    titulo: 'Prospección Orgánica "Straight Line"',
    desc: "Script de conexión, entrega de valor y CTA. Lead Magnet, embudo de conversión por autoridad y calendario de cadencia diaria.",
    bonus: "Cadencia de referidos (pedido, contacto y seguimiento).",
  },
  {
    n: "03",
    titulo: "Cierre de Venta",
    desc: "Guion técnico de llamada de descubrimiento para Google Meet, matriz de manejo de objeciones y deck de propuesta (5–7 slides).",
    bonus: "Pipeline de seguimiento (CRM simple).",
  },
  {
    n: "04",
    titulo: "Estrategia Comercial y Contenido IA",
    desc: "Oferta express con CTA claro y agentes de IA para grilla de contenidos, redacción de entregables y pricing nacional.",
    bonus: "Agente de IA para estructurar honorarios internacionales.",
  },
  {
    n: "05",
    titulo: "Landing Page y Activos Digitales",
    desc: "Landing que funciona como embudo de ventas, con CTA claro y optimización SEO, AEO y GEO.",
    bonus: "Landing estilo tarjeta digital.",
  },
];

const comparativa = [
  {
    titulo: "Google Ads",
    desc: "Caro y mal calibrado: atrae fletes B2C y curiosos, no a los gerentes de operaciones que toman decisiones de logística.",
  },
  {
    titulo: "LinkedIn Ads",
    desc: "Quemas presupuesto pagando alcance sobre un perfil orgánico débil. El anuncio amplifica una autoridad que aún no existe.",
  },
  {
    titulo: "Agencias de Redes Sociales",
    desc: "No necesitas likes ni vanity metrics. Necesitas reuniones agendadas por Meet con decisores calificados.",
  },
];

const precios = [
  { item: "Setting y Optimización de LinkedIn", usd: 300, pen: "1.125" },
  { item: "Prospección Orgánica vía LinkedIn", usd: 250, pen: "937,50" },
  { item: "Cierre de Venta", usd: 350, pen: "1.312,50" },
  { item: "Estrategia Comercial y Contenido", usd: 200, pen: "750" },
  { item: "Landing Page", usd: 200, pen: "750" },
];

const cronograma = [
  { semana: "Semana 1", hito: "Firma del contrato, pago de honorarios y análisis e investigación del caso." },
  { semana: "Semana 2", hito: "Entrega de la planificación de los servicios contratados." },
  { semana: "Semana 3", hito: "Ajustes según feedback del cliente." },
  { semana: "Semanas 4–8", hito: "Implementación y acompañamiento." },
];
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Propuesta · Kargo-Log</title>
  </head>

  <body class="bg-zinc-950 font-sans text-zinc-100 antialiased selection:bg-orange-500/30">
    <!-- ===================================================================== -->
    <!-- 1 · EL DOLOR (HERO)                                                     -->
    <!-- ===================================================================== -->
    <section class="relative overflow-hidden border-b border-zinc-800/60 px-6 py-24 sm:py-32 lg:py-40">
      <!-- Glow técnico de fondo -->
      <div
        class="pointer-events-none absolute -top-40 left-1/2 -z-10 h-[40rem] w-[40rem] -translate-x-1/2 rounded-full bg-orange-600/10 blur-[120px]"
      >
      </div>

      <div class="mx-auto max-w-4xl">
        <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-zinc-900/60 px-4 py-1.5 text-xs font-medium tracking-widest text-zinc-400 uppercase">
          <span class="h-1.5 w-1.5 rounded-full bg-orange-500"></span>
          Propuesta confidencial
        </p>

        <h1 class="text-balance text-3xl font-semibold leading-tight tracking-tight sm:text-4xl lg:text-5xl">
          25 años de excelencia operativa en empresas como
          <span class="text-white">P&amp;G</span> y <span class="text-white">Derco</span>
          no sirven de nada si los dueños de PYMES
          <span class="text-orange-400">no saben que existes.</span>
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-zinc-400">
          Pasar de repartir brochures a cerrar <span class="font-medium text-zinc-200">3 clientes
          consultivos high-ticket al año</span> requiere un sistema. Construyamos tu embudo de
          conversión predecible.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="#cta"
            class="inline-flex items-center justify-center rounded-lg bg-orange-500 px-7 py-3.5 text-sm font-semibold text-zinc-950 transition hover:bg-orange-400"
          >
            Agendar Kick-off
          </a>
          <a
            href="#sistema"
            class="inline-flex items-center justify-center rounded-lg border border-zinc-700 px-7 py-3.5 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900"
          >
            Ver el sistema
          </a>
        </div>
      </div>
    </section>

    <!-- ===================================================================== -->
    <!-- 2 · AUTORIDAD                                                           -->
    <!-- ===================================================================== -->
    <section class="border-b border-zinc-800/60 px-6 py-20 sm:py-24">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[1fr_2fr] lg:gap-16">
        <div>
          <p class="text-xs font-medium tracking-widest text-orange-400 uppercase">Autoridad</p>
          <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
            Consultoría B2B con foco en LinkedIn
          </h2>
        </div>
        <div class="space-y-5 text-lg leading-relaxed text-zinc-400">
          <p>
            Diseño y operación de <span class="text-zinc-200">embudos de conversión orgánicos</span>
            en LinkedIn para consultores y empresas técnicas de logística y operaciones. No vendemos
            humo ni alcance: construimos autoridad digital que se convierte en reuniones calificadas.
          </p>
          <p>
            El método se apoya en ecosistemas digitales de alto rendimiento —perfil, contenido,
            prospección y cierre trabajando como un solo sistema— para transformar tu trayectoria en
            un activo comercial visible y predecible.
          </p>
        </div>
      </div>
    </section>

    <!-- ===================================================================== -->
    <!-- 3 · COMPARATIVA (ESTRATEGIAS DESCARTADAS)                               -->
    <!-- ===================================================================== -->
    <section class="border-b border-zinc-800/60 px-6 py-20 sm:py-24">
      <div class="mx-auto max-w-5xl">
        <div class="max-w-2xl">
          <p class="text-xs font-medium tracking-widest text-orange-400 uppercase">Comparativa</p>
          <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
            Por qué el marketing tradicional fracasa en tu industria.
          </h2>
        </div>

        <div class="mt-12 grid gap-8 md:grid-cols-3">
          {
            comparativa.map((c) => (
              <div class="group relative rounded-xl border border-zinc-800 bg-zinc-900/40 p-7 transition hover:border-zinc-700">
                <div class="mb-5 flex h-9 w-9 items-center justify-center rounded-lg border border-red-500/30 bg-red-500/10 text-red-400">
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 5l10 10M15 5L5 15" stroke-linecap="round" />
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-zinc-100">{c.titulo}</h3>
                <p class="mt-3 text-sm leading-relaxed text-zinc-400">{c.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===================================================================== -->
    <!-- 4 · SOLUCIONES (EL SISTEMA KARGO-LOG)                                   -->
    <!-- ===================================================================== -->
    <section id="sistema" class="border-b border-zinc-800/60 px-6 py-20 sm:py-28">
      <div class="mx-auto max-w-5xl">
        <div class="max-w-2xl">
          <p class="text-xs font-medium tracking-widest text-orange-400 uppercase">El Sistema</p>
          <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
            5 módulos para un embudo predecible.
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-zinc-400">
            Cada módulo es independiente y entrega un activo concreto. Juntos, forman un sistema
            comercial de extremo a extremo.
          </p>
        </div>

        <div class="mt-14 space-y-5">
          {
            modulos.map((m) => (
              <div class="grid gap-5 rounded-xl border border-zinc-800 bg-zinc-900/40 p-7 transition hover:border-orange-500/40 sm:grid-cols-[auto_1fr] sm:gap-8 sm:p-8">
                <span class="font-mono text-2xl font-semibold text-orange-500/80 tabular-nums">
                  {m.n}
                </span>
                <div>
                  <h3 class="text-xl font-semibold text-zinc-100">{m.titulo}</h3>
                  <p class="mt-3 text-base leading-relaxed text-zinc-400">{m.desc}</p>
                  <p class="mt-4 inline-flex items-center gap-2 rounded-lg border border-orange-500/20 bg-orange-500/5 px-3 py-1.5 text-sm text-orange-300">
                    <span class="text-xs font-bold tracking-wide uppercase">Bonus</span>
                    <span class="text-zinc-300">{m.bonus}</span>
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===================================================================== -->
    <!-- 5 · SHOWCASE VISUAL (FONDO CLARO — ROMPE EL PATRÓN OSCURO)              -->
    <!-- ===================================================================== -->
    <section class="px-6 py-20 sm:py-28">
      <div class="mx-auto max-w-5xl">
        <div class="overflow-hidden rounded-3xl bg-gray-100 text-gray-900 shadow-2xl shadow-black/40">
          <div class="grid gap-10 p-8 sm:p-12 lg:grid-cols-2 lg:items-center lg:gap-14 lg:p-16">
            <!-- Copy -->
            <div>
              <p class="text-xs font-medium tracking-widest text-orange-600 uppercase">
                Previsualización Alpha
              </p>
              <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                Tu Nueva Identidad Digital:
                <span class="text-[#0A1F3C]">Kargo</span><span class="text-orange-600">-Log</span>
              </h2>
              <p class="mt-6 text-base leading-relaxed text-gray-600">
                <span class="font-semibold text-gray-900">Arquitectura de contraste.</span>
                <span class="font-semibold text-[#0A1F3C]">"KARGO"</span> (Azul Marino Oscuro)
                representa estabilidad; la flecha en
                <span class="font-semibold text-orange-600">"LOG"</span> (Naranja Industrial)
                simboliza tracción y eliminación de cuellos de botella.
              </p>

              <!-- Leyenda de paleta -->
              <div class="mt-8 flex flex-wrap gap-4">
                <div class="flex items-center gap-2">
                  <span class="h-5 w-5 rounded border border-black/10 bg-[#0A1F3C]"></span>
                  <span class="font-mono text-xs text-gray-500">#0A1F3C · Estabilidad</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="h-5 w-5 rounded border border-black/10 bg-orange-600"></span>
                  <span class="font-mono text-xs text-gray-500">#EA580C · Tracción</span>
                </div>
              </div>
            </div>

            <!-- Placeholders para activos visuales -->
            <div class="space-y-5">
              <!-- Placeholder: Isologo -->
              <div class="flex aspect-[16/7] items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-white text-center">
                <span class="px-4 text-sm font-medium text-gray-400">
                  Espacio reservado · Isologo Kargo-Log
                </span>
              </div>
              <!-- Placeholder: Landing tarjeta digital -->
              <div class="flex aspect-[16/9] items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-white text-center">
                <span class="px-4 text-sm font-medium text-gray-400">
                  Espacio reservado · Landing estilo tarjeta digital
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================================================================== -->
    <!-- 6 · PRICING, OFERTA Y CRONOGRAMA                                        -->
    <!-- ===================================================================== -->
    <section class="border-t border-zinc-800/60 px-6 py-20 sm:py-28">
      <div class="mx-auto max-w-5xl">
        <div class="max-w-2xl">
          <p class="text-xs font-medium tracking-widest text-orange-400 uppercase">Inversión</p>
          <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
            Pricing, oferta y cronograma.
          </h2>
        </div>

        <!-- Desglose + Ofertas -->
        <div class="mt-12 grid gap-8 lg:grid-cols-[3fr_2fr]">
          <!-- Tabla de precios por módulo -->
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-7 sm:p-8">
            <h3 class="text-sm font-semibold tracking-widest text-zinc-400 uppercase">
              Módulos individuales
            </h3>
            <ul class="mt-6 divide-y divide-zinc-800">
              {
                precios.map((p) => (
                  <li class="flex items-baseline justify-between gap-4 py-3.5">
                    <span class="text-sm text-zinc-300">{p.item}</span>
                    <span class="text-right whitespace-nowrap">
                      <span class="font-semibold text-zinc-100 tabular-nums">${p.usd}</span>
                      <span class="ml-2 font-mono text-xs text-zinc-500">S/ {p.pen}</span>
                    </span>
                  </li>
                ))
              }
            </ul>
            <div class="mt-5 flex items-baseline justify-between border-t border-zinc-700 pt-5">
              <span class="text-sm font-semibold tracking-wide text-zinc-200 uppercase">Total</span>
              <span class="text-right">
                <span class="text-xl font-bold text-zinc-100 tabular-nums">$1,300 USD</span>
                <span class="ml-2 font-mono text-xs text-zinc-500">S/ 4.875</span>
              </span>
            </div>
          </div>

          <!-- Ofertas -->
          <div class="space-y-5">
            <!-- Oferta 3 módulos -->
            <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
              <div class="flex items-center justify-between">
                <h3 class="text-base font-semibold text-zinc-100">3 Módulos</h3>
                <span class="rounded-full bg-zinc-800 px-3 py-1 text-xs font-bold text-zinc-300">
                  15% OFF
                </span>
              </div>
              <p class="mt-3 text-sm text-zinc-400">
                Elige tres módulos del sistema y aplica un 15% de descuento sobre el total combinado.
              </p>
            </div>

            <!-- Oferta Full Stack (destacada) -->
            <div class="relative overflow-hidden rounded-xl border border-orange-500/50 bg-gradient-to-b from-orange-500/10 to-zinc-900/40 p-6">
              <span class="absolute right-4 top-4 rounded-full bg-orange-500 px-3 py-1 text-xs font-bold text-zinc-950">
                30% OFF
              </span>
              <h3 class="text-base font-semibold text-orange-300">Full Stack · 5 Módulos</h3>
              <p class="mt-4 flex items-baseline gap-2">
                <span class="text-3xl font-bold text-white tabular-nums">$910</span>
                <span class="text-sm text-zinc-400">USD</span>
                <span class="text-sm text-zinc-500 line-through">$1,300</span>
              </p>
              <p class="mt-1 font-mono text-sm text-zinc-400">S/ 3.412,50 PEN</p>
              <p class="mt-4 text-sm text-zinc-300">El sistema completo, de extremo a extremo.</p>
            </div>
          </div>
        </div>

        <!-- Costos fijos mensuales -->
        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <div class="flex items-center justify-between rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <div>
              <p class="text-sm font-semibold text-zinc-100">Host de la Landing</p>
              <p class="mt-1 text-xs text-zinc-500">Mensual · suscripción</p>
            </div>
            <span class="text-lg font-bold text-zinc-100 tabular-nums">$5 <span class="text-sm font-normal text-zinc-400">/ mes</span></span>
          </div>
          <div class="flex items-center justify-between rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <div>
              <p class="text-sm font-semibold text-zinc-100">Host + Mantenimiento</p>
              <p class="mt-1 text-xs text-zinc-500">Mensual · suscripción</p>
            </div>
            <span class="text-lg font-bold text-zinc-100 tabular-nums">$20 <span class="text-sm font-normal text-zinc-400">/ mes</span></span>
          </div>
        </div>

        <!-- Cronograma -->
        <div class="mt-16">
          <h3 class="text-sm font-semibold tracking-widest text-zinc-400 uppercase">
            Cronograma · 8 semanas
          </h3>
          <ol class="mt-8 space-y-0 border-l border-zinc-800">
            {
              cronograma.map((c) => (
                <li class="relative pb-8 pl-8 last:pb-0">
                  <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-orange-500 ring-4 ring-zinc-950" />
                  <p class="text-sm font-semibold text-orange-300">{c.semana}</p>
                  <p class="mt-1 text-sm leading-relaxed text-zinc-400">{c.hito}</p>
                </li>
              ))
            }
          </ol>
        </div>

        <!-- Métodos de pago -->
        <div class="mt-12">
          <h3 class="text-sm font-semibold tracking-widest text-zinc-400 uppercase">
            Métodos de pago
          </h3>
          <div class="mt-6 flex flex-wrap gap-3">
            {
              [
                "Transferencia bancaria (Soles)",
                "Tarjeta de crédito (cuotas / suscripción)",
                "Criptomonedas (BTC y stablecoins L2)",
              ].map((m) => (
                <span class="rounded-lg border border-zinc-800 bg-zinc-900/40 px-4 py-2 text-sm text-zinc-300">
                  {m}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ===================================================================== -->
    <!-- CTA FINAL                                                               -->
    <!-- ===================================================================== -->
    <section id="cta" class="px-6 pb-28 pt-4">
      <div class="mx-auto max-w-3xl overflow-hidden rounded-3xl border border-zinc-800 bg-zinc-900/60 px-8 py-16 text-center sm:px-12">
        <h2 class="text-balance text-2xl font-semibold tracking-tight sm:text-3xl">
          Convirtamos 25 años de trayectoria en un embudo que vende solo.
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-zinc-400">
          Un sistema. Resultados predecibles. Empecemos por una sesión de Kick-off para definir el
          alcance y el primer activo.
        </p>
        <a
          href="#"
          class="mt-8 inline-flex items-center justify-center rounded-lg bg-orange-500 px-9 py-4 text-base font-semibold text-zinc-950 transition hover:bg-orange-400"
        >
          Agendar Kick-off
        </a>
      </div>

      <p class="mx-auto mt-10 max-w-3xl text-center text-xs text-zinc-600">
        Documento confidencial · Propuesta comercial Kargo-Log
      </p>
    </section>
  </body>
</html>
